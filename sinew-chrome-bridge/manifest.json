{
  "manifest_version": 3,
  "name": "Sinew Chrome Bridge",
  "version": "1.0.0",
  "description": "Bridges Sinew and browser-use to your active, running Chrome session.",
  "permissions": [
    "debugger",
    "tabs",
    "scripting",
    "activeTab",
    "storage",
    "downloads",
    "history",
    "notifications",
    "bookmarks",
    "tabGroups",
    "alarms",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon-32.png"
  },
  "icons": {
    "16": "icon-32.png",
    "32": "icon-32.png",
    "48": "icon-64.png",
    "128": "icon-128.png"
  }
}
